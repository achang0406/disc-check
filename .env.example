# Copy to .env.local for local development.
# On Vercel, set the VITE_* vars in Project Settings → Environment Variables.

# Supabase project URL (Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (Settings → API)
VITE_SUPABASE_ANON_KEY=your-anon-key

# Default group admin passcode when running db:seed (stored per group in Postgres)
GROUP_ADMIN_PASSCODE=0000

# Seed script only — never expose in the browser (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional alias for seed script
SUPABASE_URL=https://your-project.supabase.co

# Web Push (generate with: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Set to true when testing push via ngrok (registers the service worker in dev)
VITE_ENABLE_SW=false

# Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets)
# Set on notify-push and process-push-outbox:
# VAPID_PUBLIC_KEY=same-as-VITE_VAPID_PUBLIC_KEY
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_SUBJECT=mailto:you@example.com
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically by Supabase.
#
# Phase 2a cron (migration 034): pg_cron calls process-push-outbox every 2 min.
# Requires pg_cron + pg_net extensions and vault secret service_role_key.
